---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
	<main class="content-page contact-page">
		<section class="content-page__hero">
			<h1>Contact</h1>
			<p>Une question ? Ecrivez-nous, l'equipe vous repond rapidement.</p>
		</section>

		<section class="contact-layout">
			<form class="contact-form" method="post">
				<label>
					<span>Nom</span>
					<input type="text" name="nom" required />
				</label>

				<label>
					<span>Email</span>
					<input type="email" name="email" required />
				</label>

				<label>
					<span>Sujet</span>
					<input type="text" name="sujet" required />
				</label>

				<label>
					<span>Message</span>
					<textarea name="message" rows="5" required></textarea>
				</label>

				<button type="submit">Envoyer</button>
			</form>

			<article class="contact-details">
				<h2>Nos coordonnees</h2>
				<p>Festival La Fanfa Comtoise</p>
				<p>Parc du Prieure, 25200 Montbeliard</p>
				<p>+33 3 81 00 00 00</p>
				<p>contact@fanfa-comtoise.fr</p>

				<div class="contact-socials" aria-label="Reseaux sociaux officiels">
					<a href="https://instagram.com/fanfacomtoise" target="_blank" rel="noreferrer">Instagram</a>
					<a href="https://facebook.com/fanfacomtoise" target="_blank" rel="noreferrer">Facebook</a>
					<a href="https://x.com/fanfacomtoise" target="_blank" rel="noreferrer">X</a>
					<a href="https://youtube.com/@fanfacomtoise" target="_blank" rel="noreferrer">YouTube</a>
				</div>
			</article>
		</section>
	</main>
</Layout>
