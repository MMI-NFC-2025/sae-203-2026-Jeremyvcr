---
import Layout from '../../layouts/Layout.astro';
import { pb, getImageUrl } from '../../lib/pocketbase.js';


const { id } = Astro.params;

const artiste = await pb.collection('artistes').getOne(id);

const performances = await pb.collection('performances').getFullList({
  filter: `artistes="${id}"`,
  sort: 'date_et_heure',
  expand: 'scene'
});

const photoUrl = getImageUrl(artiste, artiste.galerie);
const firstPerformance = performances[0] ?? null;

const formatTime = (value) => new Intl.DateTimeFormat('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Europe/Paris'
}).format(new Date(value)).replace(':', 'h');

const artistFiles = [];

if (Array.isArray(artiste.galerie)) {
  artistFiles.push(...artiste.galerie);
} else if (artiste.galerie) {
  artistFiles.push(artiste.galerie);
}

if (artiste.photo_principale) {
  artistFiles.push(artiste.photo_principale);
}

const galleryUrls = [...new Set(artistFiles)]
  .map((file) => getImageUrl(artiste, file))
  .filter(Boolean);

const baseCarouselUrls = galleryUrls.length > 0 ? galleryUrls : (photoUrl ? [photoUrl] : []);
const carouselUrls = [...baseCarouselUrls];

// Force plusieurs slides pour pouvoir faire defiler le carrousel
// meme quand PocketBase contient peu d'images.
if (carouselUrls.length > 0 && carouselUrls.length < 4) {
  let index = 0;
  while (carouselUrls.length < 4) {
    carouselUrls.push(baseCarouselUrls[index % baseCarouselUrls.length]);
    index += 1;
  }
}
---

<Layout title={artiste.nom}>
  <main class="detail-page artist-detail-page">
    {photoUrl && (
      <div class="detail-page__cover">
        <img
          src={photoUrl}
          alt={`Photo de ${artiste.nom}`}
          class="detail-page__photo"
        />
      </div>
    )}

    <h1>{artiste.nom}</h1>

    <section class="artist-detail-page__block">
      <h2>Représentation</h2>
      {firstPerformance ? (
        <>
          <p class="artist-detail-page__scene">{firstPerformance.expand?.scene?.nom}</p>
          <p class="artist-detail-page__time">{formatTime(firstPerformance.date_et_heure)}</p>

          {performances.length > 0 && (
            <div class="artist-detail-page__dates-list">
              {performances.map((perf) => (
                <p>
                  {new Date(perf.date_et_heure).toLocaleDateString('fr-FR')} - {formatTime(perf.date_et_heure)}
                </p>
              ))}
            </div>
          )}
        </>
      ) : (
        <p class="artist-detail-page__empty">Programmation à venir.</p>
      )}
    </section>

    <section class="artist-detail-page__block">
      <h2>Description</h2>
      <p class="artist-detail-page__description">
        {artiste.description?.trim() || 'Description non renseignee dans PocketBase.'}
      </p>
    </section>

    <section class="artist-detail-page__block">
      <h2>Galerie</h2>
      {carouselUrls.length > 0 ? (
        <div class="artist-carousel" data-carousel>
          <button class="artist-carousel__btn artist-carousel__btn--prev" data-carousel-prev aria-label="Image précédente">‹</button>

          <div class="artist-carousel__viewport">
            <div class="artist-carousel__track" data-carousel-track>
              {carouselUrls.map((url, index) => (
                <figure class="artist-carousel__slide" data-carousel-slide aria-hidden={index === 0 ? 'false' : 'true'}>
                  <img src={url} alt={`Visuel ${index + 1} de ${artiste.nom}`} loading="lazy" />
                </figure>
              ))}
            </div>
          </div>

          <button class="artist-carousel__btn artist-carousel__btn--next" data-carousel-next aria-label="Image suivante">›</button>

          <div class="artist-carousel__dots" role="tablist" aria-label="Navigation galerie">
            {carouselUrls.map((_, index) => (
              <button
                class={`artist-carousel__dot ${index === 0 ? 'is-active' : ''}`}
                data-carousel-dot
                data-index={index}
                aria-label={`Aller à l'image ${index + 1}`}
                aria-selected={index === 0 ? 'true' : 'false'}
              />
            ))}
          </div>
        </div>
      ) : (
        <p class="artist-detail-page__empty">Aucune image disponible.</p>
      )}
    </section>
  </main>
</Layout>

<script>
  const carousels = document.querySelectorAll('[data-carousel]');

  carousels.forEach((carousel) => {
    const track = carousel.querySelector('[data-carousel-track]');
    const slides = carousel.querySelectorAll('[data-carousel-slide]');
    const prevBtn = carousel.querySelector('[data-carousel-prev]');
    const nextBtn = carousel.querySelector('[data-carousel-next]');
    const dots = carousel.querySelectorAll('[data-carousel-dot]');

    if (!track || slides.length === 0) return;

    let index = 0;
    const maxIndex = slides.length - 1;

    const render = () => {
      track.style.transform = `translateX(-${index * 100}%)`;

      slides.forEach((slide, slideIndex) => {
        slide.setAttribute('aria-hidden', slideIndex === index ? 'false' : 'true');
      });

      dots.forEach((dot, dotIndex) => {
        dot.classList.toggle('is-active', dotIndex === index);
        dot.setAttribute('aria-selected', dotIndex === index ? 'true' : 'false');
      });

      if (prevBtn) prevBtn.disabled = maxIndex === 0;
      if (nextBtn) nextBtn.disabled = maxIndex === 0;
    };

    prevBtn?.addEventListener('click', () => {
      index = index === 0 ? maxIndex : index - 1;
      render();
    });

    nextBtn?.addEventListener('click', () => {
      index = index === maxIndex ? 0 : index + 1;
      render();
    });

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const dotIndex = Number.parseInt(dot.dataset.index || '0', 10);
        if (Number.isNaN(dotIndex)) return;
        index = dotIndex;
        render();
      });
    });

    render();
  });
</script>