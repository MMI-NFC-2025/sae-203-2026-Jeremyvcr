---
import Layout from '../../layouts/Layout.astro';
import { pb } from '../../lib/pocketbase.js';
import ArtistCard from '../../components/ArtistCard.astro';

let artistes = [];
let performances = [];
try {
  artistes = await pb.collection('artistes').getFullList({ sort: 'nom' });
  performances = await pb.collection('performances').getFullList({
    sort: 'date_et_heure',
    expand: 'scene'
  });
} catch { /* PocketBase inaccessible */ }

const perfByArtiste = {};
for (const perf of performances) {
  const artisteId = perf.artistes;
  if (!artisteId) continue;
  if (!perfByArtiste[artisteId]) perfByArtiste[artisteId] = [];
  perfByArtiste[artisteId].push(perf);
}

const artistesSortedByDate = [...artistes].sort((a, b) => {
  const aFirst = perfByArtiste[a.id]?.[0]?.date_et_heure;
  const bFirst = perfByArtiste[b.id]?.[0]?.date_et_heure;
  if (!aFirst && !bFirst) return a.nom.localeCompare(b.nom, 'fr');
  if (!aFirst) return 1;
  if (!bFirst) return -1;
  return new Date(aFirst).getTime() - new Date(bFirst).getTime();
});
---

<Layout title="Artistes">
  <main class="listing-page">
    <h1>Les artistes</h1>

    {artistes.length === 0 && (
      <p class="pb-unavailable">Données indisponibles — base de données non accessible.</p>
    )}

    <section class="listing-grid">
      {artistesSortedByDate.map((artiste) => (
        <ArtistCard artiste={artiste} performances={perfByArtiste[artiste.id] ?? []} />
      ))}
    </section>
  </main>
</Layout>